  "item": [
    {
      "name": "Autenticación",
      "item": [
        {
          "name": "Iniciar Sesión (Login)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Login exitoso responde 200\", function () { pm.response.to.have.status(200); });",
                  "var jsonData = pm.response.json();",
                  "if (jsonData && jsonData.token) {",
                  "    pm.globals.set(\"beautiful_skin_jwt\", jsonData.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nickname\": \"Admin\",\n  \"password\": \"admin\"\n}"
            },
            "url": {
              "raw": "http://localhost:8050/v1/auth/login",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8050",
              "path": [
                "v1",
                "auth",
                "login"
              ]
            },
            "description": "Envía credenciales para iniciar sesión. Si es exitoso, un script guarda el JWT devuelto en la variable global {{beautiful_skin_jwt}}."
          },
          "response": []
        },
        {
          "name": "Crear Usuario",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nickname\": \"trabajador1\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:8050/v1/auth/create",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8050",
              "path": [
                "v1",
                "auth",
                "create"
              ]
            },
            "description": "Crea un usuario con contraseña BCrypt y rol ROLE_TRABAJADOR. La respuesta no expone el hash."
          },
          "response": []
        }
      ]
